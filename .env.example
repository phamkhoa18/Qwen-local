# VKS Legal AI Platform v3.0 — Environment Variables
# Copy file nay thanh .env va chinh sua truoc khi chay

APP_NAME=VKS Legal AI
APP_VERSION=3.0.0
DEBUG=false
SECRET_KEY=THAY-DOI-KEY-NAY-THANH-CHUOI-NGAU-NHIEN

# Server
HOST=0.0.0.0
PORT=8000

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=vks_legal_ai

# Ollama LLM (Local)
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=qwen3:30b-a3b

# OpenRouter (Multi-LLM Cloud — Claude, GPT-4o, Gemini)
# Dang ky tai: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=google/gemini-2.5-flash

# RAG - Embedding Model
EMBEDDING_MODEL=mainguyen9/vietlegal-harrier-0.6b

# RAG - Vector Store & Hybrid Search
VECTOR_STORE_PATH=./data/vector_store
CHUNK_SIZE=1200
CHUNK_OVERLAP=100
TOP_K=8
SIMILARITY_THRESHOLD=0.40
BM25_WEIGHT=0.4
VECTOR_WEIGHT=0.6

# Agentic RAG
AGENT_ENABLED=true
AGENT_MAX_STEPS=5

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=THAY-DOI-MAT-KHAU

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30
